    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.15",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.4.1",
    "fake-indexeddb": "^6.2.2",
    "jsdom": "^26.1.0",
    "pdfjs-dist": "^5.4.149",
